#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if command -v nix >/dev/null 2>&1; then
  echo "nix already installed"
else
  sh <(curl -L https://nixos.org/nix/install) --daemon
fi

"$repo_root/bin/apply-system-files"
"$repo_root/bin/apply-home"
